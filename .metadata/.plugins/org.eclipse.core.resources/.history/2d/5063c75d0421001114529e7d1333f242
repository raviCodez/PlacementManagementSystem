package com.placement.Service;


import com.placement.Dto.Response.StudentSummaryResponse;
import com.placement.Entity.*;
import com.placement.enums.Role;
import com.placement.Repository.*;
import com.placement.dto.request.StudentProfileUpdateRequest;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;
import java.nio.file.*;
import java.util.*;
import java.util.stream.Collectors;

@Service
@RequiredArgsConstructor
@Slf4j
public class StudentService {

    private final UserRepository           userRepository;
    private final StudentProfileRepository profileRepository;
    private final ApplicationRepository    applicationRepository;
    private final FeedbackRepository       feedbackRepository;
    private final CompanyRepository        companyRepository;

    @Value("${file.upload.dir}")
    private String uploadDir;

    // ── GET STUDENT PROFILE ───────────────────────────────────────────────
    public StudentSummaryResponse getStudentProfile(Long userId) {
        User user = userRepository.findById(userId)
            .orElseThrow(() -> new RuntimeException("User not found: " + userId));

        StudentProfile profile = profileRepository.findByUserId(userId)
            .orElseThrow(() -> new RuntimeException("Student profile not found."));

        return toSummaryResponse(user, profile);
    }

    // ── UPDATE STUDENT PROFILE ────────────────────────────────────────────
    @Transactional
    public StudentSummaryResponse updateProfile(Long userId,
                                                 StudentProfileUpdateRequest req) {
        StudentProfile profile = profileRepository.findByUserId(userId)
            .orElseThrow(() -> new RuntimeException("Student profile not found."));

        // Only update fields that are present in the request (null-safe)
        if (req.getCgpa()           != null) profile.setCgpa(req.getCgpa());
        if (req.getMarks10th()      != null) profile.setMarks10th(req.getMarks10th());
        if (req.getMarks12th()      != null) profile.setMarks12th(req.getMarks12th());
        if (req.getBacklogCount()   != null) profile.setBacklogCount(req.getBacklogCount());
        if (req.getSection()        != null) profile.setSection(req.getSection());
        if (req.getGraduationYear() != null) profile.setGraduationYear(req.getGraduationYear());

        // Convert List<String> skills → comma-separated string
        if (req.getSkills() != null && !req.getSkills().isEmpty()) {
            String skillsStr = req.getSkills()
                .stream()
                .map(String::trim)
                .filter(s -> !s.isBlank())
                .collect(Collectors.joining(","));
            profile.setSkills(skillsStr);
        }

        StudentProfile saved = profileRepository.save(profile);
        log.info("Profile updated for userId: {}", userId);

        return toSummaryResponse(profile.getUser(), saved);
    }

    // ── UPLOAD RESUME ─────────────────────────────────────────────────────
    @Transactional
    public String uploadResume(Long userId, MultipartFile file) throws IOException {

        // 1. Validate file type — only PDF allowed
        String originalName = file.getOriginalFilename();
        if (originalName == null || !originalName.toLowerCase().endsWith(".pdf")) {
            throw new RuntimeException("Only PDF resumes are accepted.");
        }

        // 2. Validate file size — max 5MB
        if (file.getSize() > 5 * 1024 * 1024) {
            throw new RuntimeException("Resume must be under 5MB.");
        }

        // 3. Create upload directory if it doesn't exist
        Path uploadPath = Paths.get(uploadDir);
        if (!Files.exists(uploadPath)) {
            Files.createDirectories(uploadPath);
        }

        // 4. Generate unique filename to prevent overwrites
        String fileName = "resume_" + userId + "_"
            + System.currentTimeMillis() + ".pdf";
        Path filePath = uploadPath.resolve(fileName);

        // 5. Save file to disk
        Files.copy(file.getInputStream(), filePath,
            StandardCopyOption.REPLACE_EXISTING);

        // 6. Update resume URL in student profile
        StudentProfile profile = profileRepository.findByUserId(userId)
            .orElseThrow(() -> new RuntimeException("Student profile not found."));

        String resumeUrl = "/resumes/" + fileName;
        profile.setResumeUrl(resumeUrl);
        profileRepository.save(profile);

        log.info("Resume uploaded for userId: {} → {}", userId, resumeUrl);
        return resumeUrl;
    }

    // ── GET ALL STUDENTS (with optional filters) ───────────────────────────
    public List<StudentSummaryResponse> getAllStudents(Long departmentId,
                                                        String section,
                                                        Boolean isPlaced) {
        return userRepository.filterStudents(departmentId, section, isPlaced)
            .stream()
            .map(user -> {
                StudentProfile profile = profileRepository
                    .findByUserId(user.getId())
                    .orElse(null);
                return toSummaryResponse(user, profile);
            })
            .collect(Collectors.toList());
    }

    // ── GET STUDENTS BY DEPARTMENT ─────────────────────────────────────────
    public List<StudentSummaryResponse> getStudentsByDepartment(Long departmentId) {
        return userRepository.findStudentsByDepartment(departmentId)
            .stream()
            .map(user -> {
                StudentProfile profile = profileRepository
                    .findByUserId(user.getId()).orElse(null);
                return toSummaryResponse(user, profile);
            })
            .collect(Collectors.toList());
    }

    // ── ADMIN: UPDATE PLACEMENT STATUS MANUALLY ────────────────────────────
    @Transactional
    public StudentSummaryResponse updatePlacementStatus(Long studentId,
                                                         boolean isPlaced,
                                                         Long companyId,
                                                         java.math.BigDecimal packageAmt) {
        StudentProfile profile = profileRepository.findByUserId(studentId)
            .orElseThrow(() -> new RuntimeException("Student profile not found."));

        profile.setPlaced(isPlaced);

        if (isPlaced && companyId != null) {
            Company company = companyRepository.findById(companyId)
                .orElseThrow(() -> new RuntimeException("Company not found."));
            profile.setPlacedCompany(company);
            profile.setPackageOffered(
                packageAmt != null ? packageAmt : company.getPackageOffered());
        } else if (!isPlaced) {
            // Unmark placement if admin corrects a mistake
            profile.setPlacedCompany(null);
            profile.setPackageOffered(null);
        }

        StudentProfile saved = profileRepository.save(profile);
        return toSummaryResponse(profile.getUser(), saved);
    }

    // ── ENTITY → DTO MAPPER ───────────────────────────────────────────────
    public StudentSummaryResponse toSummaryResponse(User user,
                                                      StudentProfile profile) {
        StudentSummaryResponse res = new StudentSummaryResponse();
        res.setUserId(user.getId());
        res.setName(user.getName());
        res.setEmail(user.getEmail());
        res.setDepartmentName(user.getDepartment() != null
            ? user.getDepartment().getName() : null);

        if (profile != null) {
            res.setRollNumber(profile.getRollNumber());
            res.setSection(profile.getSection());
            res.setCgpa(profile.getCgpa());
            res.setBacklogCount(profile.getBacklogCount());
            res.setSkills(profile.getSkills());
            res.setPlaced(profile.isPlaced());
            res.setPlacedCompanyName(profile.getPlacedCompany() != null
                ? profile.getPlacedCompany().getName() : null);
            res.setPackageOffered(profile.getPackageOffered());
            res.setResumeUrl(profile.getResumeUrl());
        }

        return res;
    }
}
