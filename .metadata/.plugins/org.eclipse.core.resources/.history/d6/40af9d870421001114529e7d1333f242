package com.placement.Service;


import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.mail.SimpleMailMessage;
import org.springframework.mail.javamail.JavaMailSender;
import org.springframework.mail.javamail.MimeMessageHelper;
import org.springframework.scheduling.annotation.Async;
import org.springframework.stereotype.Service;

import com.placement.entity.Company;

import jakarta.mail.MessagingException;
import jakarta.mail.internet.MimeMessage;

@Service
@RequiredArgsConstructor
@Slf4j
public class EmailService {

    private final JavaMailSender mailSender;

    // ── GENERIC SIMPLE EMAIL ──────────────────────────────────────────────
    @Async
    public void sendSimpleEmail(String toEmail, String subject, String body) {
        try {
            SimpleMailMessage message = new SimpleMailMessage();
            message.setTo(toEmail);
            message.setSubject(subject);
            message.setText(body);
            message.setFrom("placements@college.edu");
            mailSender.send(message);
            log.info("Simple email sent to: {}", toEmail);
        } catch (Exception e) {
            log.error("Failed to send email to {}: {}", toEmail, e.getMessage());
            // Don't rethrow — email failure must NOT break the main transaction
        }
    }

    // ── COMPANY DRIVE ANNOUNCEMENT ────────────────────────────────────────
    @Async
    public void sendCompanyDriveEmail(String toEmail, Company company) {
        try {
            MimeMessage message = mailSender.createMimeMessage();
            MimeMessageHelper helper = new MimeMessageHelper(message, true, "UTF-8");

            helper.setTo(toEmail);
            helper.setFrom("placements@college.edu");
            helper.setSubject("🎯 New Drive: " + company.getName());
            helper.setText(buildDriveEmailHtml(company), true); // true = HTML

            mailSender.send(message);
            log.info("Drive email sent to: {} for company: {}",
                toEmail, company.getName());
        } catch (MessagingException e) {
            log.error("Failed to send drive email to {}: {}", toEmail, e.getMessage());
        }
    }

    // ── SHORTLIST NOTIFICATION ────────────────────────────────────────────
    @Async
    public void sendShortlistEmail(String toEmail, Company company) {
        try {
            MimeMessage message = mailSender.createMimeMessage();
            MimeMessageHelper helper = new MimeMessageHelper(message, true, "UTF-8");

            helper.setTo(toEmail);
            helper.setFrom("placements@college.edu");
            helper.setSubject("✅ Shortlisted at " + company.getName());
            helper.setText(buildShortlistEmailHtml(company), true);

            mailSender.send(message);
        } catch (MessagingException e) {
            log.error("Failed to send shortlist email to {}: {}", toEmail, e.getMessage());
        }
    }

    // ── SELECTION NOTIFICATION ────────────────────────────────────────────
    @Async
    public void sendSelectionEmail(String toEmail, Company company) {
        try {
            MimeMessage message = mailSender.createMimeMessage();
            MimeMessageHelper helper = new MimeMessageHelper(message, true, "UTF-8");

            helper.setTo(toEmail);
            helper.setFrom("placements@college.edu");
            helper.setSubject("🎉 Congratulations! Selected at " + company.getName());
            helper.setText(buildSelectionEmailHtml(company), true);

            mailSender.send(message);
        } catch (MessagingException e) {
            log.error("Failed to send selection email to {}: {}", toEmail, e.getMessage());
        }
    }

    // ── HTML TEMPLATES ────────────────────────────────────────────────────
    private String buildDriveEmailHtml(Company company) {
        return """
            <html><body style="font-family: Arial, sans-serif; padding: 20px;">
              <h2 style="color: #2c3e50;">🎯 New Placement Drive Announced!</h2>
              <div style="background: #f8f9fa; padding: 15px; border-radius: 8px;">
                <h3 style="color: #3498db;">%s</h3>
                <table style="width: 100%%;">
                  <tr><td><b>Role:</b></td><td>%s</td></tr>
                  <tr><td><b>Package:</b></td><td>%.1f LPA</td></tr>
                  <tr><td><b>Drive Date:</b></td><td>%s</td></tr>
                  <tr><td><b>Location:</b></td><td>%s</td></tr>
                  <tr><td><b>Register By:</b></td><td>%s</td></tr>
                </table>
              </div>
              <p>Login to the placement portal to apply now!</p>
              <p style="color: #7f8c8d; font-size: 12px;">
                This is an automated message from the Placement Cell.
              </p>
            </body></html>
            """.formatted(
                company.getName(),
                company.getJobRole(),
                company.getPackageOffered(),
                company.getDriveDate(),
                company.getDriveLocation() != null ? company.getDriveLocation() : "TBA",
                company.getRegistrationDeadline()
            );
    }

    private String buildShortlistEmailHtml(Company company) {
        return """
            <html><body style="font-family: Arial, sans-serif; padding: 20px;">
              <h2 style="color: #27ae60;">✅ You've Been Shortlisted!</h2>
              <p>Congratulations! You have been shortlisted for
                 <b>%s</b> at <b>%s</b>.</p>
              <p>Please check the placement portal for further instructions
                 regarding the next round.</p>
              <p>Best of luck! 🍀</p>
            </body></html>
            """.formatted(company.getJobRole(), company.getName());
    }

    private String buildSelectionEmailHtml(Company company) {
        return """
            <html><body style="font-family: Arial, sans-serif; padding: 20px;">
              <h2 style="color: #f39c12;">🎉 Congratulations — You're Selected!</h2>
              <p>We are thrilled to inform you that you have been
                 <b>selected</b> for <b>%s</b> at <b>%s</b>.</p>
              <div style="background: #eafaf1; padding: 15px; border-radius: 8px;">
                <b>Package Offered: %.1f LPA</b>
              </div>
              <p>The HR team will contact you with offer letter details.</p>
              <p>Congratulations once again! 🎊</p>
            </body></html>
            """.formatted(
                company.getJobRole(),
                company.getName(),
                company.getPackageOffered()
            );
    }
}