package com.placement.Service;

import com.placement.Entity.*;
import com.placement.enums.*;
import com.placement.Repository.*;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.apache.poi.ss.usermodel.*;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;
import java.math.BigDecimal;
import java.util.*;

@Service
@RequiredArgsConstructor
@Slf4j
public class ExcelService {

    private final UserRepository userRepository;
    private final StudentProfileRepository profileRepository;
    private final DepartmentRepository departmentRepository;
    private final ApplicationRepository applicationRepository;
    private final PasswordEncoder passwordEncoder;

    // ── BULK STUDENT UPLOAD ──────────────────
    @Transactional
    public Map<String, Object> bulkUploadStudents(MultipartFile file) throws IOException {

        List<String> errors = new ArrayList<>();
        List<String> success = new ArrayList<>();
        int rowNum = 1;

        try (Workbook workbook = new XSSFWorkbook(file.getInputStream())) {

            Sheet sheet = workbook.getSheetAt(0);

            for (Row row : sheet) {

                if (rowNum++ == 1) continue; // skip header
                final int currentRow = rowNum;

                try {

                    String name = getCellString(row, 0);
                    String email = getCellString(row, 1);
                    String deptCode = getCellString(row, 2);
                    String rollNo = getCellString(row, 3);
                    double cgpa = getCellNumeric(row, 4);
                    double m10th = getCellNumeric(row, 5);
                    double m12th = getCellNumeric(row, 6);
                    int backlogs = (int) getCellNumeric(row, 7);
                    int gradYear = (int) getCellNumeric(row, 8);

                    // Check email already exists
                    if (userRepository.existsByEmail(email)) {
                        errors.add("Row " + currentRow + ": Email already exists - " + email);
                        continue;
                    }

                    // Find department
                    Department dept = departmentRepository.findByCode(deptCode)
                            .orElseGet(() -> {
                                errors.add("Row " + currentRow + ": Department not found - " + deptCode);
                                return null;
                            });

                    if (dept == null) continue;

                    // Create User
                    User user = User.builder()
                            .name(name)
                            .email(email)
                            .password(passwordEncoder.encode("Student@123"))
                            .role(Role.STUDENT)
                            .department(dept)
                            .isActive(true)
                            .build();

                    userRepository.save(user);

                    // Create Student Profile
                    StudentProfile profile = StudentProfile.builder()
                            .user(user)
                            .rollNumber(rollNo)
                            .cgpa(BigDecimal.valueOf(cgpa))
                            .marks10th(BigDecimal.valueOf(m10th))
                            .marks12th(BigDecimal.valueOf(m12th))
                            .backlogCount(backlogs)
                            .graduationYear(gradYear)
                            .isPlaced(false)
                            .build();

                    profileRepository.save(profile);

                    success.add(email);

                } catch (Exception e) {
                    errors.add("Row " + currentRow + ": " + e.getMessage());
                }
            }
        }

        Map<String, Object> result = new LinkedHashMap<>();
        result.put("uploaded", success.size());
        result.put("failed", errors.size());
        result.put("errors", errors);

        return result;
    }

    // ── BULK RESULT UPLOAD ───────────────────
    @Transactional
    public Map<String, Object> bulkUploadResults(MultipartFile file, Long companyId) throws IOException {

        List<String> errors = new ArrayList<>();
        List<String> updated = new ArrayList<>();
        int rowNum = 1;

        try (Workbook workbook = new XSSFWorkbook(file.getInputStream())) {

            Sheet sheet = workbook.getSheetAt(0);

            for (Row row : sheet) {

                if (rowNum++ == 1) continue;
                final int currentRow = rowNum;

                String email = getCellString(row, 0);
                String status = getCellString(row, 1).toUpperCase();

                try {

                    User student = userRepository.findByEmail(email)
                            .orElseThrow(() -> new RuntimeException("Email not found: " + email));

                    Application app = applicationRepository
                            .findByStudentIdAndCompanyId(student.getId(), companyId)
                            .orElseThrow(() ->
                                    new RuntimeException("No application for " + email));

                    ApplicationStatus appStatus = ApplicationStatus.valueOf(status);

                    app.setStatus(appStatus);
                    applicationRepository.save(app);

                    if (appStatus == ApplicationStatus.SELECTED) {

                        StudentProfile profile = profileRepository
                                .findByUserId(student.getId())
                                .orElseThrow();

                        profile.setPlaced(true);
                        profileRepository.save(profile);
                    }

                    updated.add(email + " → " + status);

                } catch (Exception e) {
                    errors.add("Row " + currentRow + ": " + e.getMessage());
                }
            }
        }

        Map<String, Object> result = new LinkedHashMap<>();
        result.put("updated", updated.size());
        result.put("failed", errors.size());
        result.put("errors", errors);

        return result;
    }

    // ── Helper Methods ───────────────────────

    private String getCellString(Row row, int col) {

        Cell cell = row.getCell(col);

        if (cell == null) return "";

        cell.setCellType(CellType.STRING);

        return cell.getStringCellValue().trim();
    }

    private double getCellNumeric(Row row, int col) {

        Cell cell = row.getCell(col);

        if (cell == null) return 0;

        return cell.getNumericCellValue();
    }
}